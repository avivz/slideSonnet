% slidesonnet.sty — LaTeX package for slideSonnet narration directives
%
% Defines \say, \silent, and \skip as no-ops so that Beamer presentations
% compile normally with pdflatex. The slideSonnet tool parses these commands
% directly from the .tex source.
%
% Usage in preamble:
%   \usepackage{slidesonnet}
%
% Usage in frames:
%   \say{Narration text for this slide.}
%   \say[voice=alice, pace=slow]{Text with voice override.}
%   \silent   % intentionally no narration
%   \skip     % omit slide from video

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidesonnet}[2025/02/24 slideSonnet narration directives]

% \say[optional]{text} — narration directive (ignored by LaTeX)
\newcommand{\say}[2][]{}

% \silent — marks slide as intentionally silent
\newcommand{\silent}{}

% Note: \skip is already a TeX primitive, so we redefine it only inside frames.
% Users should use \slidesonnetskip if \skip conflicts.
\newcommand{\slidesonnetskip}{}
