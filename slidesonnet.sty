% slidesonnet.sty — LaTeX package for slideSonnet narration directives
%
% Defines \say, \nonarration, and \slidesonnetskip as no-ops so that Beamer
% presentations compile normally with pdflatex. The slideSonnet tool parses
% these commands directly from the .tex source.
%
% Usage in preamble:
%   \usepackage{slidesonnet}
%
% Usage in frames:
%   \say{Narration text for this slide.}
%   \say[voice=alice, pace=slow]{Text with voice override.}
%   \nonarration        % intentionally no narration
%   \slidesonnetskip    % omit slide from video

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{slidesonnet}[2025/02/24 slideSonnet narration directives]

% \say[optional]{text} — narration directive (ignored by LaTeX)
\newcommand{\say}[2][]{}

% \nonarration[duration] — marks slide as intentionally silent (optional duration in seconds)
\newcommand{\nonarration}[1][]{}

% \slidesonnetskip — omit frame from video entirely
% Note: \skip is a TeX primitive (length register) and is NOT redefined here.
\newcommand{\slidesonnetskip}{}
